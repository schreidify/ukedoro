# PostgreSQL connection string (required for db:import and dev server / Drizzle).
# For Supabase: Dashboard → Project Settings → Database → Connection string.
# Use "Session pooler" (or "Transaction pooler") — NOT "Direct connection".
# Direct uses db.<ref>.supabase.co, which often resolves to IPv6 only; without IPv6 you get
# EHOSTUNREACH (e.g. 2600:1f16:...:5432). Pooler hosts (e.g. *.pooler.supabase.com:6543) use IPv4.
# Paste the full URI the dashboard gives you; do not hand-edit the direct host onto pooler.
DATABASE_URL=postgresql://username:password@localhost:5432/ukedoro

# Supabase (optional; required for Supabase Auth / client when using @/lib/supabase/client)
# Exposed to the Vite client via envPrefix — use NEXT_PUBLIC_* as in the Supabase dashboard snippets.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=YOUR_PUBLISHABLE_KEY
